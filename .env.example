# =============================================================================
# Hermes File-Watcher Telegram Skill — Environment Secrets
# =============================================================================
# Copy this file to ~/.hermes/.env and fill in your actual values.
# NEVER commit the real .env file to version control.
# Run: chmod 600 ~/.hermes/.env
# =============================================================================

# --- Telegram Bot Configuration ----------------------------------------------

# Your Telegram Bot Token from @BotFather
# Get one at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# The chat ID where notifications will be sent
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# Optional: webhook secret for payload validation
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# --- Hermes Dashboard Auth (optional — for remote backend) -------------------

# HERMES_DESKTOP_REMOTE_URL="http://your-remote-server-ip:9119"
# HERMES_DESKTOP_IGNORE_EXISTING=1

# HERMES_DASHBOARD_OAUTH_CLIENT_ID="agent:your_unique_instance_id"
# HERMES_DASHBOARD_PUBLIC_URL="https://your-public-dashboard-domain.com"

# --- Hermes Dashboard Basic Auth (trusted LAN/VPN only) ----------------------

# HERMES_DASHBOARD_BASIC_AUTH_USERNAME="admin"
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD="your-strong-password"
# HERMES_DASHBOARD_BASIC_AUTH_SECRET="32_byte_secure_hmac_session_signing_key_here"
# HERMES_DASHBOARD_BASIC_AUTH_TTL_SECONDS=43200
